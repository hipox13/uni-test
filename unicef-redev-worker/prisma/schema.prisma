/////////////////////////////////////////////////
// REDEV – NEW TABLES FOR REDEV FEATURES
// See docs/REDEV_NEW_TABLES_SUMMARY.md for rationale
/////////////////////////////////////////////////

/// Lead / non-donation form submissions. CMS: Lead submissions list, Lead data export. Website: General forms (surveys, contact, lead gen).
model RedevLeadSubmission {
  id        BigInt   @id @default(autoincrement())
  formId    Int?     // optional FK to RedevWebForm when form is registered
  source    String?  // page slug, campaign slug, or "contact" etc.
  email     String?
  name      String?
  phone     String?
  payload   String?  // JSON: other form fields
  metaData  String?
  createdAt DateTime @default(now())

  form      RedevWebForm? @relation(fields: [formId], references: [id])
  @@map("redev_lead_submission")
}

/// Redirect rules. CMS/Admin: Page redirects list. Governance: Redirect management (URL, IP/geo).
model RedevRedirect {
  id          Int      @id @default(autoincrement())
  sourcePath  String?  // from URL or pattern
  targetUrl   String?
  type        String?  // internal | external | geo
  countryCode String?
  ipRange     String?
  priority    Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("redev_redirect")
}

/// Donor Portal: Saved payment methods (PSP token, masked card). Used for "Saved payment methods", "Update payment method".
model RedevDonorPaymentMethod {
  id         BigInt   @id @default(autoincrement())
  userId     Int
  gateway    String?  // xendit | midtrans | doku
  tokenOrId  String?  // PSP token or masked reference
  last4      String?
  brand      String?  // visa | mastercard | etc
  isDefault  Boolean  @default(false)
  createdAt  DateTime @default(now())

  user       UniUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("redev_donor_payment_method")
}

/// Donor Portal + CMS: Refund request and approval. "Request refund", "Refund status", "Donor care approve/reject".
model RedevRefundRequest {
  id              BigInt   @id @default(autoincrement())
  transactionRefId String
  userId          Int?     // donor who requested
  requestedAt     DateTime @default(now())
  reason          String?
  status          String?  // pending | approved | rejected
  reviewedBy      Int?
  reviewedAt      DateTime?
  responseMessage String?

  transaction  UniTransaction @relation(fields: [transactionRefId], references: [refId])
  user         UniUser?       @relation("RefundRequestUser", fields: [userId], references: [id])
  reviewer     UniUser?       @relation("RefundReviewer", fields: [reviewedBy], references: [id])

  @@map("redev_refund_request")
}

/// Donor Portal: Communication preferences & marketing consent history. "Communication preferences", "Marketing consent history".
model RedevConsentHistory {
  id        BigInt   @id @default(autoincrement())
  userId    Int
  channel   String?  // email | sms | whatsapp | push
  topic     String?  // marketing | transactional | etc
  consented Boolean
  changedAt DateTime @default(now())
  source    String?  // portal | admin | api

  user      UniUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("redev_consent_history")
}

/// Donor Portal: Support tickets. "Support tickets", "Create and track help cases".
model RedevSupportTicket {
  id         BigInt   @id @default(autoincrement())
  userId     Int
  subject    String?
  body       String?
  status     String?  // open | pending | resolved | closed
  priority   Int?
  assignedTo Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  closedAt   DateTime?

  user       UniUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("redev_support_ticket")
}

/// Donor Portal: Address book. "Address book", "Store, label, set default billing & shipping".
model RedevDonorAddress {
  id               BigInt   @id @default(autoincrement())
  userId           Int
  label            String?  // Home | Office | Billing | Shipping
  address          String?
  city             String?
  postalCode       String?
  region           String?
  country          String?
  isDefaultBilling Boolean  @default(false)
  isDefaultShipping Boolean @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user             UniUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("redev_donor_address")
}

/// Authoring: Inline comments on pages/donations. "Inline comments" (Google-Docs-style notes).
model RedevContentComment {
  id         BigInt   @id @default(autoincrement())
  pageId     BigInt?  // set when commenting on a page
  donationId Int?     // set when commenting on a donation/campaign
  blockId    String?  // optional: block key in body JSON
  authorId   Int
  comment    String?
  resolvedAt DateTime?
  resolvedBy Int?
  createdAt  DateTime @default(now())

  page       UniPage?     @relation("CommentOnPage", fields: [pageId], references: [id], onDelete: Cascade)
  donation   UniDonation? @relation("CommentOnDonation", fields: [donationId], references: [id], onDelete: Cascade)
  author     UniUser     @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@map("redev_content_comment")
}

/// Authoring: Reusable content blocks library. "Reusable modules library", "Content blocks library".
model RedevContentBlock {
  id        BigInt   @id @default(autoincrement())
  name      String?
  slug      String?  @unique
  body      String?  // JSON block definition
  type      String?  // accordion | carousel | faq | card | etc
  authorId  Int?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("redev_content_block")
}

/// Website Security: Block by country or IP. "Block country/IPs" (config at site/market level).
model RedevSecurityBlock {
  id       Int     @id @default(autoincrement())
  type     String? // country | ip
  value    String? // country code or IP/CIDR
  scope    String? // global | market | site
  isActive Boolean @default(true)
  createdAt DateTime @default(now())

  @@map("redev_security_block")
}

/// Admin/Data: Web form definitions (non-donation). "Web-forms list", general forms integrated with CRM.
model RedevWebForm {
  id          Int      @id @default(autoincrement())
  name        String?
  slug        String?  @unique
  description String?
  schema      String?  // JSON: form fields definition
  targetUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  submissions RedevLeadSubmission[]
  @@map("redev_web_form")
}

/// Value max: Personalized URLs (upgrade, save, reactivate, extra cash, pledge conversion, payment update). Short-lived tokens for one-click donor actions.
model RedevPersonalizedLink {
  id        BigInt   @id @default(autoincrement())
  token     String   @unique
  type      String?  // upgrade | save | reactivate | extra_cash | pledge_conversion | payment_update
  userId    Int?
  refId     String?  // transaction refId when relevant
  expiresAt DateTime?
  usedAt    DateTime?
  createdAt DateTime @default(now())

  transaction UniTransaction? @relation(fields: [refId], references: [refId])
  user        UniUser?        @relation(fields: [userId], references: [id])

  @@map("redev_personalized_link")
}

/// Donor Portal: Capture interests/campaigns and survey responses. "Capture interests/campaigns", "Capture surveys/questions".
model RedevDonorInterest {
  id     BigInt   @id @default(autoincrement())
  userId Int
  source String?  // campaign slug or form id
  key    String?  // interest/campaign code
  value  String?  // JSON or string response
  createdAt DateTime @default(now())

  user   UniUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("redev_donor_interest")
}

/// Website Checkout: Abandoned donation/cart for recovery emails. "Abandoned donation (cart) recovery".
model RedevAbandonedCart {
  id         BigInt   @id @default(autoincrement())
  email      String?
  sessionId  String?
  articleId  Int?     // donation/campaign id
  amount     BigInt?
  step       Int?
  payload    String?  // JSON snapshot
  emailSentAt DateTime?
  createdAt  DateTime @default(now())

  @@map("redev_abandoned_cart")
}

/// Donor Portal / Auth: SSO, Passkey, MFA linkage. "Social/SSO login", "Passkey/biometric", "Multi-factor authentication".
model RedevUserAuthMethod {
  id         BigInt   @id @default(autoincrement())
  userId     Int
  provider   String?  // sso_google | sso_apple | passkey | mfa_totp
  providerId String?  // external id from provider
  meta       String?  // JSON: extra config (e.g. passkey credential id)
  createdAt  DateTime @default(now())

  user       UniUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("redev_user_auth_method")
}
