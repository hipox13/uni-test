generator client {
  provider = "prisma-client-js"
  engineType = "binary"
}

datasource db {
  provider = "postgresql"
}

/////////////////////////////////////////////////
// USER & AUTH
/////////////////////////////////////////////////

model UniUser {
  id             Int      @id @default(autoincrement())
  email          String?
  password       String?
  name           String?
  roleId         Int?
  gender         Int?
  status         Int?
  dateRegistered DateTime?
  dateActivated  DateTime?
  birthDate      DateTime?
  picture        String?
  phoneNumber    String?
  address        String?
  city           String?
  postalCode     String?
  region         String?
  logAttempts    Int?
  logTimeout     Int?
  metaData       String?
  logChange      Int?
  lang           String?
  ipSignup       String?

  role           UniUserRole? @relation(fields: [roleId], references: [id])

  loggedTokens   UniUserLoggedToken[]
  passwordLogs   UniUserPasswordHistory[]
  reqTokens      UniUserReqtoken[]
  roleHistory    UniRoleHistory[] @relation("UserRole")
  roleChangedBy  UniRoleHistory[] @relation("ChangedBy")
  transactions   UniTransaction[]
  donationsAuthored UniDonation[] @relation("DonationAuthor")
  donationsModified UniDonation[] @relation("DonationModifier")
  donationEdits  UniDonationEdits[] @relation("DonationEdits")
  faqsAuthored   UniDataFaq[] @relation("FaqAuthor")
  faqsModified   UniDataFaq[] @relation("FaqModifier")
  banksAuthored  UniDataBank[] @relation("BankAuthor")
  locationsAuthored UniDataLocation[] @relation("LocationAuthor")
  supportsAuthored UniDataSupport[] @relation("SupportAuthor")
  testimoniesAuthored UniDataTestimony[] @relation("TestimonyAuthor")
  pagesAuthored  UniPage[] @relation("PageAuthor")
  pagesModified  UniPage[] @relation("PageModifier")
  pageEdits      UniPageEdits[] @relation("PageEdits")
  pageVersions   UniPageVersion[] @relation("PageVersionAuthor")
  donationVersions UniDonationVersion[] @relation("DonationVersionAuthor")
  placeholdersAuthored UniPlaceholder[] @relation("PlaceholderAuthor")
  placeholdersModified UniPlaceholder[] @relation("PlaceholderModifier")
  mediasAuthored UniMedia[] @relation("MediaAuthor")
  menusAuthored  UniMenu[] @relation("MenuAuthor")
  menusModified  UniMenu[] @relation("MenuModifier")
  logActivities  UniLogActivity[] @relation("LogActivity")
  generatedEcerts UniCustomEcert[] @relation("EcertGenerator")
  userRolesV2    UniUserRolesV2[] @relation("UserRolesV2")
  donorAddresses    RedevDonorAddress[]
  donorPaymentMethods RedevDonorPaymentMethod[]
  consentHistory    RedevConsentHistory[]
  supportTickets    RedevSupportTicket[]
  donorInterests    RedevDonorInterest[]
  userAuthMethods   RedevUserAuthMethod[]
  refundRequestsAsUser RedevRefundRequest[] @relation("RefundRequestUser")
  refundReviews     RedevRefundRequest[] @relation("RefundReviewer")
  contentComments   RedevContentComment[]
  personalizedLinks RedevPersonalizedLink[]

  @@map("uni_user")
}

model UniUserRole {
  id        Int    @id @default(autoincrement())
  title     String?
  name      String?
  groupName String?
  permissions String?
  reports   String?

  users        UniUser[]
  rolePerms    UniRolePermissionsV2[]
  roleHistory  UniRoleHistory[]
  userRolesV2  UniUserRolesV2[] @relation("UserRolesV2")

  @@map("uni_user_role")
}

model UniUserLoggedToken {
  id           BigInt   @id @default(autoincrement())
  userId       Int
  token        String?
  loggedFrom   String?
  userAgent    String?
  dateLogged   DateTime?
  dateLastVisit DateTime?
  ipLogged     String?
  ipLastVisit  String?
  expires      DateTime?

  user         UniUser @relation(fields: [userId], references: [id])

  @@map("uni_user_logged_token")
}

model UniUserPasswordHistory {
  id              Int      @id @default(autoincrement())
  userId          Int
  oldPasswordHash String?
  changeAt        DateTime?

  user            UniUser @relation(fields: [userId], references: [id])

  @@map("uni_user_password_history")
}

model UniUserReqtoken {
  id          Int      @id @default(autoincrement())
  authType    Int?
  authToken   String?
  userId      Int?
  dateCreated DateTime?
  dateExpired DateTime?
  ipAddress   String?
  attempts    Int?
  userAgent   String?
  requestData String?

  user        UniUser? @relation(fields: [userId], references: [id])

  @@map("uni_user_reqtoken")
}

/////////////////////////////////////////////////
// ROLE & PERMISSION
/////////////////////////////////////////////////

model UniPermissionsV2 {
  id     Int    @id @default(autoincrement())
  module String?
  action String?

  roles  UniRolePermissionsV2[]

  @@map("uni_permissions_v2")
}

model UniRolePermissionsV2 {
  roleId       Int
  permissionId Int

  role         UniUserRole      @relation(fields: [roleId], references: [id])
  permission   UniPermissionsV2 @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("uni_role_permissions_v2")
}

model UniRoleHistory {
  id        Int      @id @default(autoincrement())
  userId    Int?
  roleId    Int?
  action    String?
  changeBy  Int?
  changeAt  DateTime?

  user      UniUser?     @relation("UserRole", fields: [userId], references: [id])
  role      UniUserRole? @relation(fields: [roleId], references: [id])
  changer   UniUser?     @relation("ChangedBy", fields: [changeBy], references: [id])

  @@map("uni_role_history")
}

/////////////////////////////////////////////////
// CMS / CONTENT
/////////////////////////////////////////////////

model UniDonation {
  id               Int       @id @default(autoincrement())
  donateType       Int?
  title            String?
  slug             String?
  description      String?
  keywords         String?
  body             String?
  bodyOneOff       String?
  authorId         Int?
  modifierId       Int?
  dateCreated      DateTime?
  datePublished    DateTime?
  dateUnpublished  DateTime?
  dateInactive     DateTime?
  dateModified     DateTime?
  status           Int?
  specialTag       Int?
  specialTags      String?
  campaignType     Int?
  usedForAds       Int?
  featured         Int?
  picture          String?
  mobilePicture    String?
  ecertMonthly     String?
  ecertOneOff      String?
  thumbnail        String?
  thankyouPicture  String?
  monthlyParams    String?
  oneoffParams     String?
  template         String?
  widDateStart     DateTime?
  widDateEnd       DateTime?
  widParams        String?
  widPicture       String?
  metaData         String?
  accessRoles      String?

  author      UniUser? @relation("DonationAuthor", fields: [authorId], references: [id])
  modifier    UniUser? @relation("DonationModifier", fields: [modifierId], references: [id])
  transactions UniTransaction[] @relation("DonationTransactions")
  edits       UniDonationEdits[] @relation("DonationEdits")
  versions    UniDonationVersion[] @relation("DonationVersions")
  downloadLogs UniDownloadLog[]
  contentComments RedevContentComment[] @relation("CommentOnDonation")

  @@map("uni_donation")
}

model UniDonationEdits {
  articleId    Int
  userId       Int
  isActive     Int?
  lastActiveAt Int?

  article      UniDonation @relation("DonationEdits", fields: [articleId], references: [id])
  user         UniUser @relation("DonationEdits", fields: [userId], references: [id])

  @@id([articleId, userId])
  @@map("uni_donation_edits")
}

model UniDonationVersion {
  id         BigInt   @id @default(autoincrement())
  donationId Int
  title      String?
  body       String?  // JSON snapshot
  version    Int
  authorId   Int?
  createdAt  DateTime @default(now())

  donation   UniDonation @relation("DonationVersions", fields: [donationId], references: [id], onDelete: Cascade)
  author     UniUser?    @relation("DonationVersionAuthor", fields: [authorId], references: [id])

  @@map("uni_donation_version")
}

model UniDonationTag {
  id    Int     @id @default(autoincrement())
  slug  String?
  title String?

  @@map("uni_donation_tag")
}

model UniTag {
  id    Int     @id @default(autoincrement())
  slug  String?
  title String?
  owner Int?

  @@map("uni_tag")
}

model UniDataFaq {
  id          Int      @id
  parent      Int?
  slug        String?
  title       String?
  picture     String?
  answer      String?
  status      Int?
  authorId    Int?
  modifierId  Int?
  description String?
  keywords    String?
  metaData    String?
  dateCreated DateTime?
  dateModified DateTime?

  parentFaq   UniDataFaq? @relation("FaqTree", fields: [parent], references: [id])
  children    UniDataFaq[] @relation("FaqTree")
  author      UniUser? @relation("FaqAuthor", fields: [authorId], references: [id])
  modifier    UniUser? @relation("FaqModifier", fields: [modifierId], references: [id])

  @@map("uni_data_faq")
}

model UniDataBank {
  id          Int      @id @default(autoincrement())
  title       String?
  currency    String?
  description String?
  picture     String?
  status      Int?
  ordering    Int?
  authorId    Int?
  dateCreated DateTime?

  author      UniUser? @relation("BankAuthor", fields: [authorId], references: [id])

  @@map("uni_data_bank")
}

model UniDataLocation {
  id          Int      @id @default(autoincrement())
  title       String?
  address     String?
  dateStart   DateTime?
  dateEnd     DateTime?
  status      Int?
  authorId    Int?
  dateCreated DateTime?

  author      UniUser? @relation("LocationAuthor", fields: [authorId], references: [id])

  @@map("uni_data_location")
}

model UniDataSubscriber {
  id          BigInt   @id @default(autoincrement())
  name        String?
  email       String?
  phone       String?
  dateCreated DateTime?

  @@map("uni_data_subscriber")
}

model UniDataSupport {
  id          Int      @id @default(autoincrement())
  title       String?
  description String?
  picture     String?
  status      Int?
  authorId    Int?
  dateCreated DateTime?

  author      UniUser? @relation("SupportAuthor", fields: [authorId], references: [id])

  @@map("uni_data_support")
}

model UniDataTestimony {
  id          Int      @id @default(autoincrement())
  name        String?
  title       String?
  description String?
  picture     String?
  status      Int?
  authorId    Int?
  dateCreated DateTime?

  author      UniUser? @relation("TestimonyAuthor", fields: [authorId], references: [id])

  @@map("uni_data_testimony")
}

model UniPage {
  id            BigInt   @id @default(autoincrement())
  title         String?
  slug          String?
  words         String?
  body          String?
  description   String?
  keywords      String?
  authorId      Int?
  datePublished DateTime?
  dateCreated   DateTime?
  dateModified  DateTime?
  type          Int?
  status        Int?
  picture       String?
  mobilePicture String?
  ecertTemplate String?
  ecertText     String?
  ecertFilename String?
  modifierId    Int?
  metaData      String?
  template      String?
  dateUnpublished DateTime?
  dateInactive    DateTime?
  trash           Int? @default(0)

  author      UniUser? @relation("PageAuthor", fields: [authorId], references: [id])
  modifier    UniUser? @relation("PageModifier", fields: [modifierId], references: [id])
  edits       UniPageEdits[] @relation("PageEdits")
  versions    UniPageVersion[] @relation("PageVersions")
  contentComments RedevContentComment[] @relation("CommentOnPage")

  @@map("uni_page")
}

model UniPageEdits {
  pageId       BigInt
  userId       Int
  isActive     Int?
  lastActiveAt Int?

  page         UniPage @relation("PageEdits", fields: [pageId], references: [id])
  user         UniUser @relation("PageEdits", fields: [userId], references: [id])

  @@id([pageId, userId])
  @@map("uni_page_edits")
}

model UniPlaceholder {
  id          Int      @id @default(autoincrement())
  name        String?
  type        Int?
  content     String?
  status      Int?
  authorId    Int?
  modifierId  Int?
  dateCreated DateTime?
  dateModified DateTime?

  author      UniUser? @relation("PlaceholderAuthor", fields: [authorId], references: [id])
  modifier    UniUser? @relation("PlaceholderModifier", fields: [modifierId], references: [id])

  @@map("uni_placeholder")
}

model UniMetadata {
  id        Int     @id @default(autoincrement())
  scope     String?
  metaKey   String?
  metaValue String?
  site      String?
  status    Int?

  @@map("uni_metadata")
}

/////////////////////////////////////////////////
// MEDIA & MENU
/////////////////////////////////////////////////

model UniMedia {
  id          BigInt   @id @default(autoincrement())
  parent      BigInt?
  name        String?
  title       String?
  caption     String?
  description String?
  extension   String?
  fileSize    Int?
  mediaType   String?
  authorId    Int?
  datePosted  DateTime?
  ordering    Int?
  status      Int?
  metaData    String?
  labels      String?

  parentMedia UniMedia?  @relation("MediaTree", fields: [parent], references: [id])
  children    UniMedia[] @relation("MediaTree")
  author      UniUser? @relation("MediaAuthor", fields: [authorId], references: [id])

  @@map("uni_media")
}

model UniMenu {
  id         Int      @id @default(autoincrement())
  parent     Int?
  groupName  String?
  title      String?
  href       String?
  target     String?
  svgIcon    String?
  status     Int?
  ordering   Int?
  authorId   Int?
  modifierId Int?
  dateCreated DateTime?
  dateModified DateTime?
  posX       Float?    @default(0)
  posY       Float?    @default(0)

  parentMenu UniMenu?  @relation("MenuTree", fields: [parent], references: [id])
  children   UniMenu[] @relation("MenuTree")
  author     UniUser? @relation("MenuAuthor", fields: [authorId], references: [id])
  modifier   UniUser? @relation("MenuModifier", fields: [modifierId], references: [id])

  @@map("uni_menu")
}

/////////////////////////////////////////////////
// PAYMENT CHANNEL
/////////////////////////////////////////////////

model UniPaymentChannel {
  id             Int     @id @default(autoincrement())
  parent         Int?
  title          String?
  name           String?
  code           String?
  phoneRequired  Int?
  paymentType    Int?
  paymentGateway String?
  status         Int?
  ordering       Int?

  transactions     UniTransaction[]
  transactionPaids UniTransactionPaid[]

  @@map("uni_payment_channel")
}

/////////////////////////////////////////////////
// TRANSACTION CORE (BUSINESS KEY refId)
/////////////////////////////////////////////////

model UniTransaction {
  id                BigInt    @id @default(autoincrement())
  refId             String    @unique
  userId            Int?
  articleId         Int?
  campaignType      Int?
  donateType        Int?
  paymentType       Int?
  paymentChannelId  Int?
  paymentGateway    String?
  amount            BigInt?
  firstName         String?
  lastName          String?
  email             String?
  phone             String?
  address           String?
  status            Int?
  regStatus         Int?
  regPaidChannel    Int?
  regPaidAt         DateTime?
  giftStatus        Int?
  dateCreated       DateTime?
  lastUpdated       DateTime?
  userAgent         String?
  ipAddress         String?
  isMobile          Int?
  utm_source        String?
  utm_medium        String?
  utm_content       String?
  utm_campaign      String?
  utm_term          String?
  words             String?
  metaData          String?
  legacyId          Int?
  trash             Int?
  mail_status       Int?
  paidChannel       Int?
  lastPaidAt        DateTime?
  badRequest        Int?
  flag              Int?
  salesforce        Int?
  consent           String?
  modifierId        Int?
  lastModified      DateTime?
  nextScheduleAt    DateTime?
  salesforceRetries Int?
  failedMessage     String?

  user           UniUser? @relation(fields: [userId], references: [id])
  article        UniDonation? @relation("DonationTransactions", fields: [articleId], references: [id])
  paymentChannel UniPaymentChannel? @relation(fields: [paymentChannelId], references: [id])
  paids          UniTransactionPaid[]
  responses      UniTransactionResponse[]
  weeklies       UniTransactionWeekly[]
  paymentLinks   UniTransactionPaymentlink[]
  ecerts         UniCustomEcert[]
  shortenLinks   UniZShortenLink[]
  downloadLogs   UniDownloadLog[] @relation("DownloadTransaction")
  gopayRetries   UniGopayRetries[] @relation("GopayRetry")
  salesforcePaymentlinks UniSalesforcePaymentlink[] @relation("SalesforcePaymentlink")
  salesforceResponses UniSalesforceResponse[] @relation("SalesforceResponse")
  xenditReminders UniXenditReminderPaymentLink[] @relation("XenditReminder")
  refundRequests   RedevRefundRequest[]
  personalizedLinks RedevPersonalizedLink[]

  @@map("uni_transaction")
}

model UniTransactionPaid {
  id                BigInt   @id @default(autoincrement())
  refId             String
  responseId        BigInt?
  paymentType       Int?
  paymentChannelId  Int?
  paymentGateway    String?
  amount            BigInt?
  paidValid         Int?
  paidAmount        BigInt?
  donateType        Int?
  status            Int?
  invoiceId         String?
  invoiceDate       DateTime?
  paidAt            DateTime?
  dateCreated       DateTime?
  cycleNumber       Int?
  flag              Int?
  salesforceRetries Int?
  isWeekly          Int?
  failedMessage     String?

  transaction      UniTransaction @relation(fields: [refId], references: [refId])
  paymentChannel   UniPaymentChannel? @relation(fields: [paymentChannelId], references: [id])
  response         UniTransactionResponse? @relation("PaidResponse", fields: [responseId], references: [id])
  weeklies         UniTransactionWeekly[]

  @@map("uni_transaction_paid")
}

model UniTransactionResponse {
  id             BigInt   @id @default(autoincrement())
  refId          String
  responseRefId  String?
  status         String?
  dateCreated    DateTime?
  responseType   Int?
  callbackSlug   String?
  paymentGateway String?
  responseText   String?
  flag           Int?
  payload        String?

  transaction UniTransaction @relation(fields: [refId], references: [refId])
  paids       UniTransactionPaid[] @relation("PaidResponse")

  @@map("uni_transaction_response")
}

model UniTransactionWeekly {
  id             BigInt   @id @default(autoincrement())
  refId          String
  paidId         BigInt?
  type           String?
  paymentGateway String?
  invoiceId      String?
  invoiceDate    DateTime?
  paidAmount     BigInt?
  lastPaidAt     DateTime?
  dateCreated    DateTime?

  transaction UniTransaction @relation(fields: [refId], references: [refId])
  paid        UniTransactionPaid? @relation(fields: [paidId], references: [id])

  @@map("uni_transaction_weekly")
}

model UniTransactionPaymentlink {
  id             BigInt   @id @default(autoincrement())
  refId          String
  invoiceId      String?
  externalId     String?
  paymentLinkUrl String?
  issuedDate     DateTime?
  paidAt         DateTime?
  amount         BigInt?
  status         Int?

  transaction UniTransaction @relation(fields: [refId], references: [refId])

  @@map("uni_transaction_paymentlink")
}

/////////////////////////////////////////////////
// LOGGING & UTIL
/////////////////////////////////////////////////

model UniLogActivity {
  id          BigInt   @id @default(autoincrement())
  dataId      String?
  userId      Int?
  dataBefore  String?
  dataAfter   String?
  dateCreated DateTime?
  feature     String?
  action      String?
  ipAddress   String?

  user        UniUser? @relation("LogActivity", fields: [userId], references: [id])

  @@map("uni_log_activity")
}

model UniClickWaBubble {
  id          Int      @id @default(autoincrement())
  user_agent  String?
  page_title  String?
  total_click Int?
  date_created DateTime?
  updated_at  DateTime?

  @@map("uni_click_wa_bubble")
}

model UniMailSent {
  id          Int      @id @default(autoincrement())
  mailSubject String?
  mailFrom    String?
  mailTo      String?
  mailBody    String?
  mailDate    DateTime?

  @@map("uni_mail_sent")
}

model UniDownloadLog {
  id             BigInt   @id @default(autoincrement())
  refId          String
  articleId      Int?
  status         Int?
  userAgent      String?
  ipAddress      String?
  isMobile       Int?
  attemptedAt    DateTime?
  failedMessage  String?

  transaction    UniTransaction @relation("DownloadTransaction", fields: [refId], references: [refId])
  article        UniDonation? @relation(fields: [articleId], references: [id])

  @@map("uni_download_log")
}

model UniDownloadUtmEcertifLog {
  id             BigInt   @id @default(autoincrement())
  name           String?
  amount         BigInt?
  status         Int?
  isMobile       Int?
  attemptedAt    DateTime?
  failedMessage  String?

  @@map("uni_download_utm_ecertif_log")
}

model UniGopayRetries {
  id         Int      @id @default(autoincrement())
  refId      String
  orderId    String?
  cycles     Int?
  lastUpdate DateTime?

  transaction UniTransaction @relation("GopayRetry", fields: [refId], references: [refId])

  @@map("uni_gopay_retries")
}

model UniSalesforcePaymentlink {
  id          BigInt   @id @default(autoincrement())
  refId       String
  invoiceId   String?
  invoiceLink String?
  invoiceDate DateTime?
  dateCreated DateTime?
  hasSent     Int?

  transaction UniTransaction @relation("SalesforcePaymentlink", fields: [refId], references: [refId])

  @@map("uni_salesforce_paymentlink")
}

model UniSalesforceResponse {
  id            Int      @id @default(autoincrement())
  salesforceId  String?
  status        String?
  type          String?
  message       String?
  contactId     String?
  refId         String
  responseText  String?
  payload       String?
  statusPayment Int?
  dateCreated   DateTime?

  transaction   UniTransaction @relation("SalesforceResponse", fields: [refId], references: [refId])

  @@map("uni_salesforce_response")
}

model UniXenditReminderPaymentLink {
  id           BigInt   @id @default(autoincrement())
  refId        String
  externalId   String?
  invoiceId    String?
  amount       BigInt?
  invoiceUrl   String?
  type         String?
  attemptRetry Int?
  expiryDate   DateTime?
  dateCreated  DateTime?
  hasSent      Int?

  transaction  UniTransaction @relation("XenditReminder", fields: [refId], references: [refId])

  @@map("uni_xendit_reminder_payment_link")
}

model UniUserPermission {
  id    Int     @id @default(autoincrement())
  name  String?
  title String?

  @@map("uni_user_permission")
}

model UniUserRolesV2 {
  userId Int
  roleId Int

  user   UniUser     @relation("UserRolesV2", fields: [userId], references: [id])
  role   UniUserRole @relation("UserRolesV2", fields: [roleId], references: [id])

  @@id([userId, roleId])
  @@map("uni_user_roles_v2")
}

model UniPageVersion {
  id        BigInt   @id @default(autoincrement())
  pageId    BigInt
  title     String?
  slug      String?
  body      String?  // JSON snapshot
  version   Int
  authorId  Int?
  createdAt DateTime @default(now())

  page      UniPage  @relation("PageVersions", fields: [pageId], references: [id], onDelete: Cascade)
  author    UniUser? @relation("PageVersionAuthor", fields: [authorId], references: [id])

  @@map("uni_page_version")
}

// Redundant UniDonationVersion removed from here and consolidated above.

/////////////////////////////////////////////////
// EXTERNAL & LEGACY
/////////////////////////////////////////////////

model UniCustomEcert {
  id             Int    @id
  refId          String
  donorName      String?
  donationAmount BigInt?
  donationType   String?
  campaign       String?
  textSetup      String?
  dateCreated    DateTime?
  generatedBy    Int?

  transaction    UniTransaction @relation(fields: [refId], references: [refId])
  generator      UniUser? @relation("EcertGenerator", fields: [generatedBy], references: [id])

  @@map("uni_custom_ecert")
}

model UniZShortenLink {
  id       Int    @id @default(autoincrement())
  refId    String
  token    String?
  username String?

  transaction UniTransaction @relation(fields: [refId], references: [refId])

  @@map("uni_z_shorten_link")
}

/////////////////////////////////////////////////
// WEB LEGACY TABLES
/////////////////////////////////////////////////

model WebDokuRcrregNotify {
  id            Int      @id @default(autoincrement())
  statustype    String?
  message       String?
  errorcode     String?
  billnumber    String?
  status        String?
  cardnumber    String?
  mallid        String?
  words         String?
  customerid    String?
  chainmerchant String?
  createdAt     DateTime?

  @@map("web_doku_rcrreg_notify")
}

model WebMidtransCallback {
  id                   Int      @id @default(autoincrement())
  campaignId           String?
  invoiceId            String?
  orderId              String?
  merchantId           String?
  transactionId        String?
  transactionStatus    String?
  transactionTime      DateTime?
  settlementTime       DateTime?
  currency             String?
  grossAmount          String?
  paymentType          String?
  fraudStatus          String?
  statusCode           String?
  statusMessage        String?
  createdAt            DateTime?
  updatedAt            DateTime?
  emailTransferNotif   Int?
  emailInitNotif       Int?
  emailRcrregNotif     Int?
  emailRcrNotif        Int?

  @@map("web_midtrans_callback")
}

