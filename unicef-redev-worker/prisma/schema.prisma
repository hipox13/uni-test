  articleId             Int?
  transIdMerchant       String?
  billNumber            String?
  transactionId         String?
  transactionUser       String?
  transactionType       String?
  transactionAmount     String?
  transactionDate       DateTime?
  transactionVia        String?
  transactionBank       String?
  transactionStatus     String?
  userNameTitle         String?
  userName              String?
  userEmail             String?
  userPhone             String?
  userAddress           String?
  userIpAddress         String?
  utmSource             String?
  utmMedium             String?
  utmContent            String?
  utmCampaign           String?
  utmTerm               String?
  emailTransferNotif    Int?
  emailInitNotif        Int?
  emailRcrregNotif      Int?
  emailSuccessNotif     Int?
  cardType              String?
  isDelete              Int?
  isPause               Int?
  isGimmick             Int?

  @@map("web_transaction")
}

model WebXenditCallback {
  id                      Int      @id @default(autoincrement())
  invoiceId               String?
  externalId              String?
  userId                  String?
  recurringPaymentId      String?
  merchant                String?
  email                   String?
  description             String?
