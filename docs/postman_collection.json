{
  "info": {
    "_postman_id": "unicef-redev-poc-v1",
    "name": "UNICEF Redev POC",
    "description": "Complete API collection for UNICEF Redev POC — CMS, Donor Portal, Payment (Midtrans Sandbox).\n\nBase URL: http://localhost:3002\n\nDefault credentials:\n- Email: admin@unicef.org\n- Password: password123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{accessToken}}",
        "type": "string"
      }
    ]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3002" },
    { "key": "accessToken", "value": "" },
    { "key": "userId", "value": "1" },
    { "key": "pageId", "value": "1" },
    { "key": "articleId", "value": "1" },
    { "key": "mediaId", "value": "1" },
    { "key": "menuId", "value": "1" },
    { "key": "tagId", "value": "1" },
    { "key": "roleId", "value": "1" },
    { "key": "refId", "value": "" }
